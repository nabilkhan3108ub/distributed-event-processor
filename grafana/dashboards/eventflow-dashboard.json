{
  "annotations": { "list": [] },
  "description": "EventFlow Distributed Event Processing Engine - Real-time Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "📊 EventFlow Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Events Ingested (Total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 100000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "eventflow_events_ingested_total",
          "legendFormat": "Total Ingested"
        }
      ]
    },
    {
      "title": "Events Processed (Total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "eventflow_events_processed_total",
          "legendFormat": "Total Processed"
        }
      ]
    },
    {
      "title": "Failed Events",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "eventflow_events_failed_total",
          "legendFormat": "Total Failed"
        }
      ]
    },
    {
      "title": "Anomalies Detected",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "eventflow_anomalies_detected_total",
          "legendFormat": "Anomalies"
        }
      ]
    },
    {
      "title": "🚀 Throughput",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Ingestion Rate (events/sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "rate(eventflow_events_ingested_total[1m])",
          "legendFormat": "Ingested/sec"
        },
        {
          "expr": "rate(eventflow_events_processed_total[1m])",
          "legendFormat": "Processed/sec"
        }
      ]
    },
    {
      "title": "Rate Limited Requests",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          },
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "rate(eventflow_requests_rate_limited_total[1m])",
          "legendFormat": "Rate Limited/sec"
        }
      ]
    },
    {
      "title": "⏱️ Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Ingestion Latency (p50, p95, p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "eventflow_ingestion_latency_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50"
        },
        {
          "expr": "eventflow_ingestion_latency_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95"
        },
        {
          "expr": "eventflow_ingestion_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Cassandra Write Latency (p50, p95, p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "eventflow_cassandra_write_latency_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50"
        },
        {
          "expr": "eventflow_cassandra_write_latency_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95"
        },
        {
          "expr": "eventflow_cassandra_write_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Kafka Publish Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "eventflow_kafka_publish_latency_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50"
        },
        {
          "expr": "eventflow_kafka_publish_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Processing Pipeline Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "eventflow_processing_latency_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50"
        },
        {
          "expr": "eventflow_processing_latency_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["eventflow", "kafka", "cassandra"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EventFlow Dashboard",
  "uid": "eventflow-main",
  "version": 1
}
